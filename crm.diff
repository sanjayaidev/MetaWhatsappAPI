+// ── SHEET WATCHERS (new-row auto-send + date reminders, approved templates) ──
+let watcherSheetsCache = [], watcherColumnsCache = [], watcherTemplatesCache = [], currentWatcherId = null;
+const WATCH_TYPE_LABEL = { new_row: '🆕 New Row', date_reminder: '🎂 Date Reminder' };
+
+async function loadSheetWatchers() {
+  const data = await apiCall('/api/sheet-watchers');
+  const el = document.getElementById('watchersList');
+  if (data.error || !data.watchers || !data.watchers.length) {
+    el.innerHTML = '<div class="empty-state"><div class="empty-icon">🔔</div><p>No sheet watchers yet. Connect a Google Sheet under Sources first, then add one here.</p></div>';
+    return;
+  }
+  el.innerHTML = data.watchers.map(w => {
+    const schedule = w.watch_type === 'date_reminder'
+      ? `${w.offset_days > 0 ? w.offset_days + 'd before' : 'on the day'} · every ${w.poll_interval_minutes}m`
+      : `every ${w.poll_interval_minutes}m`;
+    const status = w.last_error ? `<span class="badge badge-red" title="${escapeHtml(w.last_error)}">Error</span>`
+      : w.active ? '<span class="badge badge-green">Active</span>' : '<span class="badge badge-gray">Paused</span>';
+    return `<div class="data-row">
+      <div><div class="data-row-title">${WATCH_TYPE_LABEL[w.watch_type] || w.watch_type} — ${escapeHtml(w.spreadsheet_name || w.spreadsheet_id)} / ${escapeHtml(w.worksheet)}</div>
+      <div class="data-row-sub">${SOURCE_ICON[w.channel] || ''} ${w.channel} · ${schedule} · last checked ${timeAgo(w.last_polled_at)}</div></div>
+      <div class="data-row-actions">${status}
+        <button class="btn btn-ghost btn-xs" onclick="pollWatcherNow('${w.id}')">▶ Poll now</button>
+        <button class="btn btn-ghost btn-xs" onclick="editWatcher('${w.id}')">✏️</button>
+        <button class="btn btn-ghost btn-xs" onclick="deleteWatcher('${w.id}')">🗑</button>
+      </div></div>`;
+  }).join('');
+}
+
+async function openWatcherModal(id) {
+  currentWatcherId = id || null;
+  document.getElementById('watcherModalTitle').textContent = id ? 'Edit Sheet Watcher' : 'New Sheet Watcher';
+  document.getElementById('watcherType').value = 'new_row';
+  document.getElementById('watcherChannel').value = 'whatsapp';
+  document.getElementById('watcherOffsetDays').value = 0;
+  document.getElementById('watcherPollInterval').value = '15';
+  document.getElementById('watcherActive').checked = true;
+  document.getElementById('watcherMessageTemplate').value = '';
+  document.getElementById('watcherWorksheetSelect').innerHTML = '<option value="">Select sheet first</option>';
+  document.getElementById('watcherWorksheetSelect').disabled = true;
+  ['watcherNameCol','watcherPhoneCol','watcherEmailCol','watcherDateCol'].forEach(elId => document.getElementById(elId).innerHTML = '<option value="">— none —</option>');
+  renderWatcherFields();
+  openModal('watcherModal');
+
+  const [sheetsData, templatesData] = await Promise.all([
+    apiCall('/api/oauth/google/sheets'),
+    apiCall('/api/templates')
+  ]);
+  watcherSheetsCache = sheetsData.sheets || [];
+  const sheetSelect = document.getElementById('watcherSheetSelect');
+  sheetSelect.innerHTML = watcherSheetsCache.length
+    ? watcherSheetsCache.map(s => `<option value="${s.id}">${escapeHtml(s.name)}</option>`).join('')
+    : '<option value="">No sheets found — connect Google Sheets under Sources</option>';
+
+  watcherTemplatesCache = (templatesData.templates || []).filter(t => t.status === 'APPROVED');
+  const tplSelect = document.getElementById('watcherTemplateSelect');
+  tplSelect.innerHTML = watcherTemplatesCache.length
+    ? watcherTemplatesCache.map(t => `<option value="${t.id}">${escapeHtml(t.name)}</option>`).join('')
+    : '<option value="">No approved templates yet — submit one under Campaigns</option>';
+
+  if (id) {
+    const data = await apiCall('/api/sheet-watchers');
+    const w = (data.watchers || []).find(x => x.id === id);
+    if (!w) return;
+    document.getElementById('watcherType').value = w.watch_type;
+    document.getElementById('watcherChannel').value = w.channel;
+    document.getElementById('watcherOffsetDays').value = w.offset_days || 0;
+    document.getElementById('watcherPollInterval').value = String(w.poll_interval_minutes || 15);
+    document.getElementById('watcherActive').checked = !!w.active;
+    document.getElementById('watcherMessageTemplate').value = w.message_template || '';
+    renderWatcherFields();
+    if (watcherSheetsCache.some(s => s.id === w.spreadsheet_id)) {
+      sheetSelect.value = w.spreadsheet_id;
+      await onWatcherSheetSelected();
+      const wsSelect = document.getElementById('watcherWorksheetSelect');
+      if ([...wsSelect.options].some(o => o.value === w.worksheet)) {
+        wsSelect.value = w.worksheet;
+        await onWatcherWorksheetSelected();
+      }
+    }
+    ['watcherNameCol','watcherPhoneCol','watcherEmailCol','watcherDateCol'].forEach((elId, i) => {
+      const col = [w.name_column, w.phone_column, w.email_column, w.date_column][i];
+      if (col) document.getElementById(elId).value = col;
+    });
+    if (w.template_id) {
+      tplSelect.value = w.template_id;
+      renderWatcherPlaceholderMapping(w.placeholder_mapping || {});
+    }
+  }
+}
+
+function renderWatcherFields() {
+  const isDateReminder = document.getElementById('watcherType').value === 'date_reminder';
+  document.getElementById('watcherDateFields').style.display = isDateReminder ? 'block' : 'none';
+  const isWhatsapp = document.getElementById('watcherChannel').value === 'whatsapp';
+  document.getElementById('watcherTemplateFields').style.display = isWhatsapp ? 'block' : 'none';
+  document.getElementById('watcherPlainMessageField').style.display = isWhatsapp ? 'none' : 'block';
+  if (!isWhatsapp) renderWatcherFieldChips();
+}
+
+async function onWatcherSheetSelected() {
+  const sheetId = document.getElementById('watcherSheetSelect').value;
+  const wsSelect = document.getElementById('watcherWorksheetSelect');
+  if (!sheetId) { wsSelect.innerHTML = '<option value="">Select sheet first</option>'; wsSelect.disabled = true; return; }
+  wsSelect.innerHTML = '<option value="">Loading…</option>';
+  const data = await apiCall(`/api/oauth/google/worksheets/${sheetId}`);
+  wsSelect.disabled = false;
+  wsSelect.innerHTML = (data.worksheets || []).map(w => `<option value="${escapeHtml(w)}">${escapeHtml(w)}</option>`).join('') || '<option value="">No tabs found</option>';
+}
+
+async function onWatcherWorksheetSelected() {
+  const sheetId = document.getElementById('watcherSheetSelect').value;
+  const worksheet = document.getElementById('watcherWorksheetSelect').value;
+  if (!sheetId || !worksheet) return;
+  const data = await apiCall(`/api/oauth/google/columns/${sheetId}/${encodeURIComponent(worksheet)}`);
+  watcherColumnsCache = data.columns || [];
+  const options = '<option value="">— none —</option>' + watcherColumnsCache.map(c => `<option value="${escapeHtml(c)}">${escapeHtml(c)}</option>`).join('');
+  ['watcherNameCol','watcherPhoneCol','watcherEmailCol','watcherDateCol'].forEach(elId => {
+    const prev = document.getElementById(elId).value;
+    document.getElementById(elId).innerHTML = options;
+    if (prev) document.getElementById(elId).value = prev;
+  });
+  renderWatcherPlaceholderMapping();
+}
+
+// Same {{1}}/{{name}} extraction approach used for campaign templates in dashboard.html.
+function getWatcherTemplatePlaceholders(tpl) {
+  if (!tpl) return { keys: [], isPositional: true };
+  const body = tpl.body || '';
+  const rawKeys = [...new Set((body.match(/\{\{([^}]+)\}\}/g) || []).map(m => m.slice(2, -2).trim()))];
+  const isPositional = rawKeys.length > 0 && rawKeys.every(k => /^\d+$/.test(k));
+  const keys = isPositional ? rawKeys.map(k => parseInt(k, 10)).sort((a, b) => a - b) : rawKeys;
+  return { keys, isPositional };
+}
+
+function renderWatcherPlaceholderMapping(existingMapping) {
+  const tplId = document.getElementById('watcherTemplateSelect').value;
+  const tpl = watcherTemplatesCache.find(t => t.id === tplId);
+  const { keys } = getWatcherTemplatePlaceholders(tpl);
+  const container = document.getElementById('watcherPlaceholderMapping');
+  if (!tpl) { container.innerHTML = ''; return; }
+  if (!keys.length) { container.innerHTML = '<div style="font-size:11px;color:var(--text3);margin-bottom:10px;">This template has no variables to map.</div>'; return; }
+
+  const colOptions = watcherColumnsCache.map(c => `<option value="field:${escapeHtml(c)}">Sheet Column: ${escapeHtml(c)}</option>`).join('');
+  container.innerHTML = `<div class="form-label">Map "${escapeHtml(tpl.name)}" variables</div>` + keys.map(key => {
+    const saved = existingMapping?.[key];
+    const savedValue = saved ? (saved.type === 'field' ? `field:${saved.field}` : saved.type === 'custom' ? 'custom' : saved.type) : 'name';
+    return `<div style="display:flex;gap:8px;align-items:center;margin-bottom:6px;">
+      <span class="tag-chip">{{${key}}}</span>
+      <select id="watcherMap_${key}" style="flex:1;" onchange="toggleWatcherCustomInput('${key}')">
+        <option value="name">Name column</option>
+        <option value="phone">Phone column</option>
+        <option value="email">Email column</option>
+        ${colOptions}
+        <option value="custom">Fixed custom text</option>
+      </select>
+      <input type="text" id="watcherMapCustom_${key}" placeholder="Custom value" style="flex:1;display:${savedValue === 'custom' ? 'block' : 'none'};" value="${saved?.type === 'custom' ? escapeHtml(saved.value || '') : ''}">
+    </div>`;
+  }).join('');
+  keys.forEach(key => { const sel = document.getElementById(`watcherMap_${key}`); if (sel) sel.value = existingMapping?.[key] ? (existingMapping[key].type === 'field' ? `field:${existingMapping[key].field}` : existingMapping[key].type) : 'name'; });
+}
+function toggleWatcherCustomInput(key) {
+  const isCustom = document.getElementById(`watcherMap_${key}`).value === 'custom';
+  document.getElementById(`watcherMapCustom_${key}`).style.display = isCustom ? 'block' : 'none';
+}
+
+function renderWatcherFieldChips() {
+  const base = ['name','phone','email'].concat(watcherColumnsCache);
+  document.getElementById('watcherFieldChips').innerHTML = base.map(t =>
+    `<span class="tag-chip" style="cursor:pointer;" onclick="insertWatcherFieldTag('${t}')">+{${t}}</span>`).join(' ');
+}
+function insertWatcherFieldTag(tag) {
+  const ta = document.getElementById('watcherMessageTemplate');
+  const pos = ta.selectionStart || ta.value.length;
+  ta.value = ta.value.slice(0, pos) + `{${tag}}` + ta.value.slice(pos);
+  ta.focus();
+}
+
+async function saveWatcher() {
+  const sheetId = document.getElementById('watcherSheetSelect').value;
+  const worksheet = document.getElementById('watcherWorksheetSelect').value;
+  if (!sheetId || !worksheet) { showToast('Pick a sheet and tab first', true); return; }
+  const channel = document.getElementById('watcherChannel').value;
+  const watch_type = document.getElementById('watcherType').value;
+  const sheetName = watcherSheetsCache.find(s => s.id === sheetId)?.name || sheetId;
+
+  const body = {
+    spreadsheet_id: sheetId, spreadsheet_name: sheetName, worksheet, watch_type,
+    name_column: document.getElementById('watcherNameCol').value || null,
+    phone_column: document.getElementById('watcherPhoneCol').value || null,
+    email_column: document.getElementById('watcherEmailCol').value || null,
+    date_column: document.getElementById('watcherDateCol').value || null,
+    offset_days: parseInt(document.getElementById('watcherOffsetDays').value) || 0,
+    channel,
+    poll_interval_minutes: parseInt(document.getElementById('watcherPollInterval').value) || 15,
+    active: document.getElementById('watcherActive').checked
+  };
+
+  if (watch_type === 'date_reminder' && !body.date_column) { showToast('Pick a date column for date reminders', true); return; }
+  if (!body.phone_column && !body.email_column) { showToast('Map at least a phone or email column so there\'s somewhere to send to', true); return; }
+
+  if (channel === 'whatsapp') {
+    const templateId = document.getElementById('watcherTemplateSelect').value;
+    if (!templateId) { showToast('Pick an approved template', true); return; }
+    const tpl = watcherTemplatesCache.find(t => t.id === templateId);
+    const { keys } = getWatcherTemplatePlaceholders(tpl);
+    const placeholder_mapping = {};
+    for (const key of keys) {
+      const sel = document.getElementById(`watcherMap_${key}`);
+      if (!sel) continue;
+      const val = sel.value;
+      if (val === 'custom') {
+        const custom = document.getElementById(`watcherMapCustom_${key}`)?.value.trim() || '';
+        if (!custom) { showToast(`Custom value required for {{${key}}}`, true); return; }
+        placeholder_mapping[key] = { type: 'custom', value: custom };
+      } else if (val.startsWith('field:')) {
+        placeholder_mapping[key] = { type: 'field', field: val.slice(6) };
+      } else {
+        placeholder_mapping[key] = { type: val }; // 'name' | 'phone' | 'email'
+      }
+    }
+    body.template_id = templateId;
+    body.placeholder_mapping = placeholder_mapping;
+  } else {
+    body.message_template = document.getElementById('watcherMessageTemplate').value.trim();
+    if (!body.message_template) { showToast('Message is required', true); return; }
+  }
+
+  const endpoint = currentWatcherId ? `/api/sheet-watchers/${currentWatcherId}` : '/api/sheet-watchers';
+  const data = await apiCall(endpoint, currentWatcherId ? 'PUT' : 'POST', body);
+  if (data.error) { showToast('Failed: ' + data.error, true); return; }
+  showToast('✅ Watcher saved'); closeModal('watcherModal'); loadSheetWatchers();
+}
+
+async function editWatcher(id) { await openWatcherModal(id); }
+async function deleteWatcher(id) {
+  if (!confirm('Delete this watcher? It will stop sending immediately.')) return;
+  await apiCall(`/api/sheet-watchers/${id}`, 'DELETE'); loadSheetWatchers();
+}
+async function pollWatcherNow(id) {
+  const data = await apiCall(`/api/sheet-watchers/${id}/poll-now`, 'POST');
+  if (data.error) { showToast('Failed: ' + data.error, true); return; }
+  showToast('Polling within 60s…'); setTimeout(loadSheetWatchers, 65000);
+}
